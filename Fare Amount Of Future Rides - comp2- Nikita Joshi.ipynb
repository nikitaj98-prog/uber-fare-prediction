   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "1fb741f0-c61e-4539-97b2-01778e33bd5c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# as column 'pickup_datetime' data-type is object , so further using it, we will have to change the data-type into datetime..\n",
    "uber_data['pickup_datetime'] = pd.to_datetime(uber_data['pickup_datetime'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "b42663d5-788d-4dfe-920b-a1fc814df2b7",
   "metadata": {},
   "outputs": [],
   "source": [
    "# to extract 'year' from the date..\n",
    "uber_data.insert(3, 'pickup_year', uber_data['pickup_datetime'].dt.year)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "20e8babf-88cf-461e-9ac9-2226a29dc478",
   "metadata": {},
   "outputs": [],
   "source": [
    "# to extract 'month' from the date...\n",
    "uber_data.insert(4, 'pickup_month', uber_data['pickup_datetime'].dt.month)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "f563795c-05cd-4f13-b3ea-e977b9bb195c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# to extract 'date' from the date...\n",
    "uber_data.insert(5, 'pickup_date', uber_data['pickup_datetime'].dt.day)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "62d12e88-429a-4401-8930-4f2af57aeb63",
   "metadata": {},
   "outputs": [],
   "source": [
    "# to extract exact 'hour' from the time...\n",
    "uber_data.insert(6, 'pickup_hour', uber_data['pickup_datetime'].dt.hour)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "a04daa14-b122-48c3-b8b7-69010ee1bfbc",
   "metadata": {},
   "outputs": [],
   "source": [
    "# to extract 'day' from the date....\n",
    "uber_data.insert(7, 'pickup_day', uber_data['pickup_datetime'].dt.dayofweek)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "id": "b44b377f-5fb7-424e-8fd5-bf773aac818c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# to create the column if the day is weekend or a weekday...\n",
    "uber_data.insert(8, 'is_weekend', uber_data['pickup_day'].apply(lambda x : 1 if x>=5 else 0))"
   ]
  },
