   "metadata": {},
   "source": [
    "## Feature-engineering "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "59e09e8c-00a1-4f13-b7f6-187c0e2751b5",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "(199999, 9)"
      ]
     },
     "execution_count": 17,
     "metadata": {},
     "output_type": "execute_result"
